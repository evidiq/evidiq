# ── EVIDIQ environment (copy to .env.local and fill in) ──────────────────────

# GitHub (used by tooling to create/push the private repo)
GITHUB_TOKEN=
GITHUB_OWNER=

# 0G — single funded EVM private key for storage + attestation (0G mainnet)
OG_PRIVATE_KEY=
OG_CHAIN_ID=16661
OG_STORAGE_RPC=https://evmrpc.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai
OG_COMPUTE_RPC=https://evmrpc.0g.ai

# 0G Compute Router — TEE-backed, OpenAI-compatible inference (sk- API key)
OG_COMPUTE_API_KEY=
OG_COMPUTE_BASE_URL=https://router-api.0g.ai/v1
OG_COMPUTE_MODEL=glm-5.2

# ── OKX ASP / x402 payment (X Layer) ─────────────────────────────────────────
# Leave X402_ASSET blank to list as a FREE A2MCP endpoint (returns results, no charge).
# To go PAID on X Layer mainnet, set ASSET (USDC) + PAY_TO + PRICE + SETTLE_KEY.
OKX_ASP_ID=
X402_CHAIN=x-layer                                     # x-layer -> eip155:196 · x-layer-testnet -> eip155:1952
X402_PAY_TO=                                           # payout address (0x…), e.g. your OKX Agentic Wallet
X402_ASSET=                                            # USDC on X Layer = 0x74b7F16337b8972027F6196A17a631aC6dE26d22 (blank = free)
X402_PRICE=0                                           # atomic units; USDC has 6 decimals -> 50000 = $0.05
X402_DOMAIN_NAME=USD Coin                              # USDC EIP-712 domain name
X402_DOMAIN_VERSION=2                                  # USDC EIP-712 domain version
X402_RPC=https://rpc.xlayer.tech                       # X Layer RPC used for on-chain settlement
X402_SETTLE_KEY=                                       # 0x… key of a gas-funded X Layer wallet -> self-settles payments
X402_USE_FACILITATOR=0                                 # 1 = use an external facilitator instead of self-settle

# Cloudflare (DNS for the domain)
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# App
NEXT_PUBLIC_SITE_URL=https://evidiq.dev
