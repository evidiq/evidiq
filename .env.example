# ── EVIDIQ environment (copy to .env.local and fill in) ──────────────────────

# GitHub (used by tooling to create/push the private repo)
GITHUB_TOKEN=
GITHUB_OWNER=

# 0G — single funded EVM private key for storage + attestation (0G mainnet)
OG_PRIVATE_KEY=
OG_CHAIN_ID=16661
OG_STORAGE_RPC=https://evmrpc.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai
OG_COMPUTE_RPC=https://evmrpc.0g.ai

# 0G Compute Router — TEE-backed, OpenAI-compatible inference (sk- API key)
OG_COMPUTE_API_KEY=
OG_COMPUTE_BASE_URL=https://router-api.0g.ai/v1
OG_COMPUTE_MODEL=glm-5.2

# OKX ASP / x402 payment (X Layer). x402 stays a free no-op until X402_ASSET is set.
OKX_ASP_ID=
X402_CHAIN=x-layer
X402_PAY_TO=
X402_ASSET=
X402_PRICE=0
X402_DOMAIN_NAME=USDT0
X402_DOMAIN_VERSION=1
X402_USE_FACILITATOR=0

# Cloudflare (DNS for the domain)
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# App
NEXT_PUBLIC_SITE_URL=https://evidiq.dev
