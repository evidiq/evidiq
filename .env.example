# ── EVIDIQ environment (copy to .env.local and fill in) ──────────────────────

# GitHub (used by tooling to create/push the private repo)
GITHUB_TOKEN=
GITHUB_OWNER=

# 0G — storage + compute + TEE (single EVM private key)
OG_PRIVATE_KEY=
OG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
OG_COMPUTE_RPC=https://evmrpc-testnet.0g.ai

# OKX ASP / x402 payment
OKX_ASP_ID=
X402_PAY_TO=
X402_CHAIN=x-layer

# Cloudflare (DNS for the domain)
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# App
NEXT_PUBLIC_SITE_URL=https://evidiq.dev
