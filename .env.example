# ── EVIDIQ environment (copy to .env.local and fill in) ──────────────────────

# GitHub (used by tooling to create/push the private repo)
GITHUB_TOKEN=
GITHUB_OWNER=

# 0G — single funded EVM private key for storage + attestation (0G mainnet)
OG_PRIVATE_KEY=
OG_CHAIN_ID=16661
OG_STORAGE_RPC=https://evmrpc.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai
OG_COMPUTE_RPC=https://evmrpc.0g.ai

# 0G Compute Router — TEE-backed, OpenAI-compatible inference (sk- API key)
OG_COMPUTE_API_KEY=
OG_COMPUTE_BASE_URL=https://router-api.0g.ai/v1
OG_COMPUTE_MODEL=glm-5.2

# ── OKX ASP / x402 payment (X Layer) ─────────────────────────────────────────
# Leave X402_ASSET blank to list as a FREE A2MCP endpoint (returns results, no charge).
# To go PAID on X Layer mainnet, set ASSET (USDT0) + PAY_TO + PRICE + SETTLE_KEY.
OKX_ASP_ID=
X402_CHAIN=x-layer                                     # x-layer -> eip155:196 · x-layer-testnet -> eip155:1952
X402_PAY_TO=                                           # payout address (0x…), e.g. your OKX Agentic Wallet
X402_ASSET=                                            # USDT0 on X Layer = 0x779ded0c9e1022225f8e0630b35a9b54be713736 (blank = free) — do NOT use USDC (0x74b7…), OKX A2MCP can't resolve its decimals
X402_PRICE=0                                           # atomic units; USDT0 has 6 decimals -> 50000 = $0.05
X402_DOMAIN_NAME=USD₮0                                 # USDT0 EIP-712 domain name (exact on-chain name)
X402_DOMAIN_VERSION=1                                  # USDT0 EIP-712 domain version
X402_RPC=https://rpc.xlayer.tech                       # X Layer RPC used for on-chain settlement
X402_SETTLE_KEY=                                       # 0x… key of a gas-funded X Layer wallet -> self-settles payments
X402_USE_FACILITATOR=0                                 # 1 = use an external facilitator instead of self-settle

# Cloudflare (DNS for the domain)
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# App
NEXT_PUBLIC_SITE_URL=https://evidiq.dev

# ── Auto-blog (writing + images REUSED from zyva-app, by design) ─────────────
BLOG_CRON_SECRET=                                      # random secret; sent as x-cron-secret by scripts/blog-cron.mjs
BLOG_LLM_API_KEY=                                      # 0G router key — REUSED from zyva-app's BLOG_LLM_API_KEY (NOT OG_COMPUTE_API_KEY: that one is glm-5.2-only, used by verify_agent)
BLOG_LLM_BASE_URL=https://router-api.0g.ai/v1          # same 0G router
BLOG_LLM_MODEL=minimax-m3                              # thinking/reasoning model, matches ZYVA's blog engine
BLOG_DO_API_KEY=                                       # DigitalOcean Inference key — REUSED from zyva-app's ZYVA_DO_API_KEY (shared quota, by design)
